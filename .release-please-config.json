{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "pull-request-title-pattern": "build${scope}: release${component} ${version}",
  "packages": {
    ".": {
      "release-type": "go",
      "versioning": "prerelease",
      "prerelease-type": "rc",
      "extra-files": [
        "VERSION.md"
      ]    
    }
  }
}
