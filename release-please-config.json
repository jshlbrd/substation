{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "pull-request-title-pattern": "build${scope}: release${component} ${version}",
  "packages": {
    ".": {
      "release-type": "go",
      "extra-files": [
        {
          "type": "generic",
          "path": "VERSION.md"
        }
      ]    
    }
  }
}
